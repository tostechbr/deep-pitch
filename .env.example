# ==========================================================================
# WC2026 Deep Agent Match Analyst — configuração
# Copie para `.env` e preencha. Só o cérebro do agente é obrigatório.
# ==========================================================================

# --- Cérebro do agente (LLM) — escolha 1 provider -------------------------
# Opções: anthropic | google | groq | openrouter | nvidia | free
#   free = cadeia de fallback entre providers GRÁTIS (sobrevive a rate limit):
#          tenta cada um da FREE_CHAIN em ordem; um cai → vai pro próximo.
MODEL_PROVIDER=anthropic
# Ordem da cadeia free (só entram os que tiverem key setada):
# FREE_CHAIN=groq,google,nvidia,openrouter
# Override opcional do modelo (senão usa o default do provider):
# MODEL_NAME=claude-sonnet-4-5-20250929

# Seleção POR PAPEL (opcional) — main = síntese (forte), subagent = scout/
# historian (barato/rápido). Se vazio, herda MODEL_PROVIDER/MODEL_NAME.
# Ex: main forte (pago) + subagents free:
# MAIN_PROVIDER=anthropic
# SUBAGENT_PROVIDER=google

# Chaves de provider (preencha só a(s) que for usar):
ANTHROPIC_API_KEY=            # melhor tool-calling → trace limpo (pago)
GOOGLE_API_KEY=               # Gemini free tier — caminho GRÁTIS que já funciona
GROQ_API_KEY=                 # Llama 3.3 70B free tier (rápido)
OPENROUTER_API_KEY=           # modelos :free (Llama/DeepSeek)
NVIDIA_API_KEY=               # NVIDIA NIM (build.nvidia.com) — free, nvapi-...

# --- Feed ao vivo (subagent scout) ----------------------------------------
# football-data.org v4 — Copa 2026 no free tier. Registro grátis em
# https://www.football-data.org/client/register → token no header X-Auth-Token.
# Sem token, o scout degrada para só busca web (o agente ainda funciona).
FOOTBALL_DATA_API_KEY=

# --- Busca qualitativa (subagent scout) -----------------------------------
# Opcional. Sem key, cai para DuckDuckGo (keyless).
TAVILY_API_KEY=

# --- Observabilidade (LangSmith) ------------------------------------------
# Trace do agente (o screenshot do post). Key grátis em https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=wc2026-analyst
